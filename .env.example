# ──────────────────────────────────────────────────────────────
# Keel — environment template. Copy to .env and fill in real values.
# .env is gitignored. NEVER commit real credentials.
# ──────────────────────────────────────────────────────────────

# MongoDB (Policy Ledger). Prisma Mongo connector.
DATABASE_URL="mongodb+srv://<user>:<password>@<cluster>.mongodb.net/keel?retryWrites=true&w=majority"

# Sui network
SUI_NETWORK="testnet"
SUI_RPC_URL="https://fullnode.testnet.sui.io:443"

# DeepBook Predict — testnet (branch predict-testnet-4-16)
PREDICT_PACKAGE_ID="0xf5ea2b3749c65d6e56507cc35388719aadb28f9cab873696a2f8687f5c785138"
PREDICT_SHARED_OBJECT_ID=""
PREDICT_INDEXER_URL="https://predict-server.testnet.mystenlabs.com"
QUOTE_ASSET_TYPE="" # e.g. 0x...::dusdc::DUSDC

# Keeper wallet (server-signs redeem_permissionless ONLY). Keep secret.
KEEPER_PRIVATE_KEY=""

# Privy (wallet connect / embedded Sui wallets). App ID is public; secret is server-only.
NEXT_PUBLIC_PRIVY_APP_ID=""
PRIVY_APP_ID=""
PRIVY_APP_SECRET="" # server-side only — never expose to the client

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
